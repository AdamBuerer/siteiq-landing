# Public site URL (no trailing slash) — used for canonical, JSON-LD, and default OG image host
VITE_SITE_URL=https://www.siteiq.com

# Optional: full URL to Open Graph / Twitter image (defaults to ${VITE_SITE_URL}/og-image.svg)
# VITE_OG_IMAGE=https://www.siteiq.com/og-image.svg

# Lead capture — pick one:
# (A) Zoho CRM web form: paste the embed/perma URL from Zoho Forms (iframe src). Easiest path into CRM.
# VITE_ZOHO_LEAD_FORM_URL=https://forms.zohopublic.com/yourorg/form/YourFormName/formperma/xxxxxxxxxxxx
#
# (B) Custom API (used only if native HTML form is shown — leave VITE_ZOHO_LEAD_FORM_URL unset):
# JSON body: { name, email, company, note }
# VITE_LEAD_ENDPOINT=https://api.example.com/v1/leads

# Optional: Sign-in URL override (defaults are set in index.html if you prefer not to use env)
# VITE_SIGNIN_URL=https://www.siteiqtechnologies.com/web/login?redirect=/index

# Landing-only layout: simplified nav/footer (set true for single-page marketing deploy)
# VITE_HOME_ONLY=true
