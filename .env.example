# Public site URL (no trailing slash) — used for canonical, JSON-LD, and default OG image host
VITE_SITE_URL=https://www.siteiq.com

# Optional: full URL to Open Graph / Twitter image (defaults to ${VITE_SITE_URL}/og-image.svg)
# VITE_OG_IMAGE=https://www.siteiq.com/og-image.svg

# Lead form POST endpoint (JSON body: { name, email, note })
# VITE_LEAD_ENDPOINT=https://api.example.com/v1/leads
